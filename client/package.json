{
  "name": "client",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "verify:scroll-pin": "node ./scripts/verify-battle-scroll-pin.mjs",
    "verify:move-timing": "node ./scripts/verify-move-timing.mjs",
    "preview": "vite preview",
